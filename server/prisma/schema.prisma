generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRADER
  BUYER
  SUPPLIER
  ADMIN
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum TradeStatus {
  PENDING
  COMPLETED
  DISPUTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(TRADER)
  company      String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings Listing[]
  orders   Order[]
  tradesBuyer  Trade[] @relation("BuyerTrades")
  tradesSeller Trade[] @relation("SellerTrades")
}

model RiceVariety {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  origin      String?
  createdAt   DateTime @default(now())

  listings Listing[]
  orders   Order[]
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String?
  pricePerKg  Decimal  @db.Decimal(10, 4)
  quantityKg  Decimal  @db.Decimal(12, 2)
  minOrderKg  Decimal  @db.Decimal(12, 2) @default(1)
  grade       String?
  moisture    Decimal? @db.Decimal(5, 2)
  location    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller   User        @relation(fields: [sellerId], references: [id])
  sellerId String
  variety  RiceVariety @relation(fields: [varietyId], references: [id])
  varietyId String
}

model Order {
  id          String      @id @default(cuid())
  type        OrderType
  status      OrderStatus @default(OPEN)
  pricePerKg  Decimal     @db.Decimal(10, 4)
  quantityKg  Decimal     @db.Decimal(12, 2)
  filledKg    Decimal     @db.Decimal(12, 2) @default(0)
  notes       String?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  userId    String
  variety   RiceVariety @relation(fields: [varietyId], references: [id])
  varietyId String

  buyTrades  Trade[] @relation("BuyOrderTrades")
  sellTrades Trade[] @relation("SellOrderTrades")
}

model Trade {
  id          String      @id @default(cuid())
  quantityKg  Decimal     @db.Decimal(12, 2)
  pricePerKg  Decimal     @db.Decimal(10, 4)
  totalAmount Decimal     @db.Decimal(15, 4)
  status      TradeStatus @default(PENDING)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  buyer      User  @relation("BuyerTrades", fields: [buyerId], references: [id])
  buyerId    String
  seller     User  @relation("SellerTrades", fields: [sellerId], references: [id])
  sellerId   String
  buyOrder   Order @relation("BuyOrderTrades", fields: [buyOrderId], references: [id])
  buyOrderId String
  sellOrder  Order @relation("SellOrderTrades", fields: [sellOrderId], references: [id])
  sellOrderId String
}

model PriceHistory {
  id          String   @id @default(cuid())
  varietyName String
  pricePerKg  Decimal  @db.Decimal(10, 4)
  volumeKg    Decimal  @db.Decimal(12, 2)
  recordedAt  DateTime @default(now())

  @@index([varietyName, recordedAt])
}
