rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All authenticated users share the same store
    match /listings/{docId} {
      allow read, write: if request.auth != null;
    }
    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }
    match /capitals/{docId} {
      allow read, write: if request.auth != null;
    }
    match /sales/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
